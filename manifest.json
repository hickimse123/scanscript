{
  "manifest_version": 3,
  "name": "ScanScript Studio",
  "version": "1.1",
  "description": "Çevirmenler için gelişmiş, satır numaralı ve auto-save destekli yan panel.",
  "permissions": ["storage", "activeTab", "scripting"],
  "action": {
    "default_title": "ScanScript Panelini Aç/Kapat"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
